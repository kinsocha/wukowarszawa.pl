---
import Default from '../../layouts/Default.astro';
import Icon from '../../components/Icon.astro';
import { siteConfig } from '../../config/site';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  return (await getCollection('poradnik'))
    .filter(({ data }) => data.pubDate.valueOf() <= Date.now())
    .map(post => ({ params: { slug: post.slug }, props: post }));
}

type Props = CollectionEntry<'poradnik'>;

const post = Astro.props;
const { Content } = await post.render();

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: siteConfig.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Poradnik', item: siteConfig.url + '/poradnik/' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: new URL(`/poradnik/${post.slug}/`, siteConfig.url).href },
  ],
});

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Organization', name: siteConfig.name },
  publisher: { '@type': 'Organization', name: siteConfig.name, url: siteConfig.url },
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  mainEntityOfPage: new URL(`/poradnik/${post.slug}/`, siteConfig.url).href,
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.data.faq.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});

const dateStr = post.data.pubDate.toLocaleDateString('pl-PL', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
  timeZone: 'Europe/Warsaw',
});
---

<Default title={`${post.data.title} | Wuko Warszawa`} description={post.data.description}>
  <script type="application/ld+json" is:inline set:html={breadcrumbSchema} />
  <script type="application/ld+json" is:inline set:html={articleSchema} />
  <script type="application/ld+json" is:inline set:html={faqSchema} />

  <!-- Hero -->
  <section class="relative pt-32 pb-14 lg:pt-40 lg:pb-16 bg-gradient-to-br from-slate-900 via-slate-800 to-sky-900 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -left-32 w-96 h-96 bg-sky-500/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay:1s"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-white/60 text-sm mb-6">
        <a href="/" class="hover:text-sky-300 transition-colors">Strona główna</a>
        <span>/</span>
        <a href="/poradnik/" class="hover:text-sky-300 transition-colors">Poradnik</a>
      </div>
      <span class="inline-block bg-white/10 backdrop-blur-sm border border-white/20 text-sky-200 font-semibold text-sm px-4 py-1.5 rounded-full mb-5">
        {post.data.category}
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-white/70 text-sm">
        <time datetime={post.data.pubDate.toISOString()}>{dateStr}</time>
        <span>{post.data.readingTime} min czytania</span>
        <span>{siteConfig.name}</span>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="py-14 lg:py-20 bg-white">
    <div class="article-content max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Content />
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-14">
      <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-6">Najczęstsze pytania</h2>
      <div class="space-y-4">
        {post.data.faq.map(item => (
          <details class="group bg-slate-50 border border-slate-100 rounded-xl">
            <summary class="flex items-center justify-between gap-4 cursor-pointer px-5 py-4 font-semibold text-slate-900 list-none [&::-webkit-details-marker]:hidden">
              {item.q}
              <Icon name="chevron-down" class="w-5 h-5 text-sky-500 flex-shrink-0 group-open:rotate-180 transition-transform" />
            </summary>
            <p class="px-5 pb-5 text-slate-600 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-14">
      <div class="bg-gradient-to-br from-sky-600 to-cyan-600 rounded-2xl p-8 lg:p-10 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3">Masz problem z kanalizacją?</h2>
        <p class="text-white/85 mb-7 leading-relaxed">
          Opisz krótko sytuację, a podpowiemy metodę i podamy wycenę przed przyjazdem.
          Działamy na terenie całej Warszawy i okolic.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/#kontakt"
            class="inline-flex items-center gap-2 bg-white text-sky-700 px-7 py-3.5 rounded-full font-semibold hover:shadow-lg transition-all hover:scale-105"
          >
            Napisz do nas
            <Icon name="arrow-right" class="w-4 h-4" />
          </a>
          <a href={`mailto:${siteConfig.email}`} class="text-white font-semibold hover:underline">
            {siteConfig.email}
          </a>
        </div>
      </div>
    </div>
  </article>
</Default>

<style is:global>
  .article-content h2 {
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    color: #0f172a;
    margin: 2.5rem 0 1rem;
  }
  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin: 2rem 0 0.75rem;
  }
  .article-content p {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #475569;
    margin-bottom: 1.25rem;
  }
  .article-content ul,
  .article-content ol {
    margin: 0 0 1.25rem 1.5rem;
    color: #475569;
    font-size: 1.125rem;
    line-height: 1.75;
  }
  .article-content ul { list-style: disc; }
  .article-content ol { list-style: decimal; }
  .article-content li { margin-bottom: 0.5rem; }
  .article-content strong { color: #0f172a; }
  .article-content a {
    color: #0284c7;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-content a:hover { color: #0369a1; }
  .article-content blockquote {
    border-left: 4px solid #38bdf8;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #475569;
    font-style: italic;
  }
  @media (min-width: 1024px) {
    .article-content h2 { font-size: 1.75rem; }
  }
</style>
