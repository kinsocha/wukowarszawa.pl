---
import Default from '../../layouts/Default.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('poradnik'))
  .filter(({ data }) => data.pubDate.valueOf() <= Date.now())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatter = new Intl.DateTimeFormat('pl-PL', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<Default
  title="Poradnik – czyszczenie i udrażnianie kanalizacji | Wuko Warszawa"
  description="Praktyczne porady o czyszczeniu kanalizacji: ceny, dobór metody, wuko czy sprężyna, deszczówka i rynny. Pisane na podstawie codziennej pracy w Warszawie."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 bg-gradient-to-br from-slate-900 via-slate-800 to-sky-900 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -left-32 w-96 h-96 bg-sky-500/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay:1s"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-white/60 text-sm mb-6">
        <a href="/" class="hover:text-sky-300 transition-colors flex items-center gap-1">
          <Icon name="arrow-left" class="w-4 h-4" /> Strona główna
        </a>
        <span>/</span>
        <span class="text-white">Poradnik</span>
      </div>
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">Poradnik</h1>
        <p class="text-lg sm:text-xl text-white/80 leading-relaxed">
          Odpowiedzi na pytania, które klienci zadają nam najczęściej: ile to kosztuje,
          którą metodę wybrać i jak nie dopuścić do kolejnego zatoru. Bez teorii z podręczników —
          tylko to, co wynika z codziennej pracy przy kanalizacji.
        </p>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="py-16 lg:py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {articles.map(article => (
          <article class="group relative bg-white rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl hover:shadow-sky-500/10 hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col">
            <div class="h-1.5 bg-gradient-to-r from-sky-500 to-cyan-500"></div>
            <div class="p-6 lg:p-8 flex flex-col flex-1">
              <div class="flex items-center gap-3 text-sm mb-4">
                <span class="inline-block bg-sky-50 text-sky-700 font-semibold px-3 py-1 rounded-full">
                  {article.data.category}
                </span>
                <time class="text-slate-500" datetime={article.data.pubDate.toISOString()}>
                  {formatter.format(article.data.pubDate)}
                </time>
              </div>
              <h2 class="text-xl font-bold text-slate-900 mb-3 leading-snug">
                <a href={`/poradnik/${article.slug}/`} class="hover:text-sky-700 transition-colors">
                  {article.data.title}
                </a>
              </h2>
              <p class="text-slate-600 leading-relaxed mb-6 flex-1">{article.data.description}</p>
              <div class="flex items-center justify-between border-t border-slate-100 pt-4">
                <span class="text-sm text-slate-500">{article.data.readingTime} min czytania</span>
                <a
                  href={`/poradnik/${article.slug}/`}
                  class="inline-flex items-center text-sky-600 font-semibold group-hover:text-sky-700"
                >
                  Czytaj
                  <Icon name="arrow-right" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Default>
