---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../config/site';
import { getCollection } from 'astro:content';

const reviewEntries = await getCollection('reviews');
const reviews = reviewEntries.map(e => e.data);

const avg = reviews.length ? reviews.reduce((s, r) => s + r.rating, 0) / reviews.length : 5;

const reviewsSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: siteConfig.name,
  url: siteConfig.url,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: avg.toFixed(1),
    bestRating: '5',
    ratingCount: reviews.length,
  },
  review: reviews.map((r) => ({
    '@type': 'Review',
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: '5' },
    author: {
      '@type': 'Person',
      name: r.location ? `Klient – ${r.location.split(',').at(-1)?.trim() ?? r.location}` : 'Klient Wuko Warszawa',
    },
    reviewBody: r.text,
    ...(r.service ? { description: r.service } : {}),
  })),
});
---

<Layout
  title="Opinie klientów – Wuko Warszawa"
  description="Opinie klientów o usługach Wuko Warszawa: udrażnianie kanalizacji, sprężyna elektryczna, Wuko, inspekcja kamerą TV."
>
  <script type="application/ld+json" is:inline set:html={reviewsSchema} />

  <!-- Hero -->
  <section class="op-hero">
    <div class="op-hero-bg">
      <div class="op-orb op-orb-1"></div>
      <div class="op-orb op-orb-2"></div>
    </div>
    <div class="op-hero-inner">
      <div class="op-crumbs">
        <a href="/"><Icon name="arrow-left" class="op-crumb-ico" /> Strona główna</a>
        <span>/</span>
        <span class="op-crumbs-current">Opinie</span>
      </div>
      <div class="op-hero-copy">
        <h1 class="op-h1">Opinie klientów</h1>
        <div class="op-rating">
          {Array.from({ length: 5 }).map(() => (
            <Icon name="star" class="op-star-big" />
          ))}
          <span class="op-rating-num">{avg.toFixed(1)}/5</span>
        </div>
        <p class="op-hero-sub">
          Tu znajdziesz oceny i komentarze osób, którym pomagaliśmy przy udrażnianiu kanalizacji
          w Warszawie i okolicach.
        </p>
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="op-reviews">
    <div class="op-wide">
      <div class="op-grid">
        {reviews.map(r => (
          <div class="op-card">
            <Icon name="quote" class="op-quote" />
            <div class="op-stars">
              {Array.from({ length: r.rating }).map(() => (
                <Icon name="star" class="op-star" />
              ))}
            </div>
            <p class="op-text">"{r.text}"</p>
            <div class="op-meta">
              {r.location && (
                <div class="op-meta-loc">
                  <Icon name="map-pin" class="op-meta-ico" />
                  <span>{r.location}</span>
                </div>
              )}
              {r.service && <div class="op-meta-service">{r.service}</div>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="op-cta">
    <div class="op-cta-inner">
      <h2 class="op-cta-title">Dołącz do zadowolonych klientów</h2>
      <p class="op-cta-sub">Zadzwoń – ustalimy termin i orientacyjny koszt usługi.</p>
      <a href={`tel:${siteConfig.phoneTel}`} class="op-cta-btn">
        <Icon name="phone" class="op-cta-ico" />
        <span>{siteConfig.phone}</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .op-wide {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .op-wide { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .op-wide { padding: 0 2rem; } }

  /* Hero */
  .op-hero {
    position: relative;
    padding: 8rem 0 4rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0c4a6e 100%);
    overflow: hidden;
  }
  @media (min-width: 1024px) { .op-hero { padding: 10rem 0 5rem; } }
  .op-hero-bg { position: absolute; inset: 0; overflow: hidden; }
  .op-orb {
    position: absolute;
    width: 24rem;
    height: 24rem;
    border-radius: 50%;
    filter: blur(64px);
    animation: op-pulse 4s ease-in-out infinite;
  }
  .op-orb-1 { top: 25%; left: -8rem; background: rgba(14, 165, 233, 0.2); }
  .op-orb-2 { bottom: 25%; right: -8rem; background: rgba(6, 182, 212, 0.2); animation-delay: 1s; }

  .op-hero-inner {
    position: relative;
    z-index: 10;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .op-hero-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .op-hero-inner { padding: 0 2rem; } }

  .op-crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
  .op-crumbs a {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .op-crumbs a:hover { color: #7dd3fc; }
  .op-crumb-ico { width: 1rem; height: 1rem; }
  .op-crumbs-current { color: #fff; }

  .op-hero-copy { text-align: center; max-width: 48rem; margin: 0 auto; }
  .op-h1 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .op-h1 { font-size: 3rem; } }
  @media (min-width: 1024px) { .op-h1 { font-size: 3.75rem; } }

  .op-rating { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem; }
  .op-star-big { width: 1.75rem; height: 1.75rem; color: #fbbf24; fill: #fbbf24; }
  .op-rating-num { font-size: 1.5rem; font-weight: 700; color: #fff; margin-left: 0.5rem; }

  .op-hero-sub { font-size: 1.125rem; color: rgba(255, 255, 255, 0.8); line-height: 1.7; }
  @media (min-width: 640px) { .op-hero-sub { font-size: 1.25rem; } }

  /* Reviews */
  .op-reviews { padding: 4rem 0; background: #fff; }
  @media (min-width: 1024px) { .op-reviews { padding: 5rem 0; } }
  .op-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .op-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .op-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-card {
    background: linear-gradient(135deg, #f0f9ff, #ecfeff);
    border-radius: 1rem;
    padding: 1.5rem;
    border: 1px solid #e0f2fe;
  }
  .op-quote { width: 2rem; height: 2rem; color: #7dd3fc; margin-bottom: 1rem; }
  .op-stars { display: flex; align-items: center; gap: 0.25rem; margin-bottom: 1rem; }
  .op-star { width: 1.25rem; height: 1.25rem; color: #fbbf24; fill: #fbbf24; }
  .op-text { color: #334155; line-height: 1.7; margin-bottom: 1rem; font-style: italic; }
  .op-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.875rem;
    color: #64748b;
    border-top: 1px solid rgba(186, 230, 253, 0.5);
    padding-top: 0.75rem;
  }
  .op-meta-loc { display: flex; align-items: center; gap: 0.5rem; }
  .op-meta-ico { width: 1rem; height: 1rem; }
  .op-meta-service { color: #0284c7; font-weight: 500; }

  /* CTA */
  .op-cta {
    padding: 4rem 0;
    background: linear-gradient(135deg, #0284c7, #0891b2);
  }
  @media (min-width: 1024px) { .op-cta { padding: 5rem 0; } }
  .op-cta-inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1rem;
    text-align: center;
  }
  @media (min-width: 640px) { .op-cta-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .op-cta-inner { padding: 0 2rem; } }
  .op-cta-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }
  @media (min-width: 640px) { .op-cta-title { font-size: 2.25rem; } }
  .op-cta-sub { font-size: 1.25rem; color: rgba(255, 255, 255, 0.9); margin-bottom: 2rem; }
  .op-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #fff;
    color: #0284c7;
    padding: 1.25rem 2.5rem;
    border-radius: 999px;
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .op-cta-btn:hover { transform: scale(1.05); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25); }
  .op-cta-ico { width: 1.5rem; height: 1.5rem; }

  @keyframes op-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
