---
import Default from '../layouts/Default.astro';
import DistrictContent from '../components/DistrictContent.astro';
import { districts } from '../data/districts';

const district = districts.find(d => d.slug === 'wukotargowek')!;
---
<Default title={district.metaTitle} description={district.metaDescription}>
  <DistrictContent district={district} />
</Default>
