---
import Layout from '../layouts/Layout.astro';
import DistrictContent from '../components/DistrictContent.astro';
import { districts } from '../data/districts';

const district = districts.find(d => d.slug === 'wukoochota')!;
---
<Layout title={district.metaTitle} description={district.metaDescription}>
  <DistrictContent district={district} />
</Layout>
