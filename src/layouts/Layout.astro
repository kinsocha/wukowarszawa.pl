---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const ratingValue = siteConfig.rating.value as number;
const ratingCount = siteConfig.rating.count as number;

const sameAs = [
  siteConfig.social.facebook,
  siteConfig.social.instagram,
  ...(siteConfig.googleMapsUrl ? [siteConfig.googleMapsUrl] : []),
];

const schemaObj: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: siteConfig.name,
  legalName: siteConfig.legalName,
  description: 'Ciśnieniowe udrażnianie i czyszczenie kanalizacji w Warszawie i okolicach.',
  url: siteConfig.url,
  image: new URL('/og-image.png', siteConfig.url).href,
  email: siteConfig.email,
  ...(siteConfig.phoneTel ? { telephone: siteConfig.phoneTel } : {}),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Warszawa',
    addressRegion: 'mazowieckie',
    addressCountry: 'PL',
  },
  areaServed: { '@type': 'City', name: 'Warszawa' },
  openingHours: siteConfig.openingHours,
  priceRange: '$$',
  foundingDate: String(siteConfig.experienceSince),
  sameAs,
};

const schema = JSON.stringify(schemaObj);

// Gwiazdki w wynikach Google: aggregateRating w CreativeWorkSeries, nie w LocalBusiness
const ratingSchema =
  ratingValue > 0 && ratingCount > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'CreativeWorkSeries',
        name: `${siteConfig.name} – ciśnieniowe udrażnianie kanalizacji`,
        url: siteConfig.url,
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue,
          bestRating: '5',
          ratingCount,
        },
      })
    : null;

const canonical = new URL(Astro.url.pathname, siteConfig.url).href;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="PL-MZ" />
    <meta name="geo.placename" content="Warszawa" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', siteConfig.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Wuko Warszawa – ciśnieniowe udrażnianie kanalizacji" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', siteConfig.url).href} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" is:inline set:html={schema} />
    {ratingSchema && <script type="application/ld+json" is:inline set:html={ratingSchema} />}
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
