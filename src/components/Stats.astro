---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
const stats = [
  { icon: 'calendar',   value: year - siteConfig.experienceSince, suffix: '+', label: 'Lat doświadczenia' },
  { icon: 'briefcase',  value: year - siteConfig.ownCompanySince,  suffix: '+', label: 'Lat własnej firmy' },
  { icon: 'building2',  value: 18,  suffix: '',  label: 'Dzielnic Warszawy' },
  { icon: 'thumbs-up',  value: 100, suffix: '%', label: 'Wycena przed pracą' },
];
---

<section class="stats">
  <div class="stats-pattern"></div>

  <div class="stats-inner">
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div
          class="stat-item"
          data-value={s.value}
          data-suffix={s.suffix}
          data-delay={i * 150}
          style="opacity:0;transform:translateY(20px);transition:all 0.6s ease-out"
        >
          <div class="stat-ico-wrap">
            <Icon name={s.icon} class="stat-ico" />
          </div>
          <div class="stat-count">0{s.suffix}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    position: relative;
    padding: 5rem 0;
    background: linear-gradient(90deg, #0f172a, #1e293b, #0f172a);
    overflow: hidden;
  }
  @media (min-width: 1024px) { .stats { padding: 6rem 0; } }

  .stats-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    background-image:
      linear-gradient(90deg, transparent 79px, #1e293b 79px, #1e293b 81px, transparent 81px),
      linear-gradient(transparent 79px, #1e293b 79px, #1e293b 81px, transparent 81px);
    background-size: 80px 80px;
  }

  .stats-inner {
    position: relative;
    z-index: 10;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .stats-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .stats-inner { padding: 0 2rem; } }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem;
  }
  @media (min-width: 1024px) { .stat-item { padding: 2rem; } }

  .stat-ico-wrap {
    padding: 1rem;
    background: rgba(14, 165, 233, 0.2);
    border-radius: 1rem;
    margin-bottom: 1rem;
    transition: background 0.2s ease;
  }
  .stat-item:hover .stat-ico-wrap { background: rgba(14, 165, 233, 0.3); }
  .stat-ico { width: 2rem; height: 2rem; color: #38bdf8; }

  .stat-count {
    font-size: 2.25rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 1024px) { .stat-count { font-size: 3rem; } }

  .stat-label { color: rgba(255, 255, 255, 0.6); text-align: center; }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.stat-item');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const value  = parseInt(el.dataset.value ?? '0');
      const suffix = el.dataset.suffix ?? '';
      const delay  = parseInt(el.dataset.delay ?? '0');
      const counter = el.querySelector('.stat-count') as HTMLElement;

      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';

      setTimeout(() => {
        let start: number;
        const duration = 2000;
        function tick(now: number) {
          if (!start) start = now;
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 4);
          counter.textContent = Math.floor(eased * value).toLocaleString() + suffix;
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }, delay);

      observer.unobserve(el);
    });
  }, { threshold: 0.5 });

  items.forEach(el => observer.observe(el));
</script>
