---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';
import { districts } from '../data/districts';

const year = new Date().getFullYear();

const services = [
  'Hydrodynamiczne Wuko',
  'Sprężyna elektryczna',
  'Inspekcja kamerą TV',
  'Mieszkania i domy',
  'Wspólnoty mieszkaniowe',
  'Lokale usługowe',
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <div class="footer-logo-bg">
            <Icon name="droplets" class="footer-logo-ico" />
          </div>
          <div class="footer-logo-text">
            <span class="footer-logo-name">{siteConfig.shortName}</span>
            <span class="footer-logo-sub">WARSZAWA</span>
          </div>
        </a>
        <p class="footer-desc">
          Ciśnieniowe udrażnianie i czyszczenie kanalizacji w Warszawie i okolicach.
          Doświadczenie od {siteConfig.experienceSince} r. – Wuko, sprężyna elektryczna,
          inspekcja kamerą TV.
        </p>
        <div class="footer-social">
          <a
            href={siteConfig.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="footer-social-link"
          >
            <Icon name="facebook" class="footer-social-ico" />
          </a>
          <a
            href={siteConfig.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="footer-social-link"
          >
            <Icon name="instagram" class="footer-social-ico" />
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="footer-heading">Usługi</h3>
        <ul class="footer-list">
          {services.map(s => (
            <li><a href="/#uslugi" class="footer-link">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Districts -->
      <div>
        <h3 class="footer-heading">Dzielnice</h3>
        <ul class="footer-list">
          {districts.map(d => (
            <li><a href={`/${d.slug}`} class="footer-link">Wuko {d.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="footer-heading">Kontakt</h3>
        <ul class="footer-list">
          <li>
            <a href={`mailto:${siteConfig.email}`} class="footer-link footer-mail">
              <Icon name="mail" class="footer-mail-ico" />
              <span class="footer-mail-text">{siteConfig.email}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">
        © {year} {siteConfig.name}. Wszystkie prawa zastrzeżone.
      </p>
      <div class="footer-legal">
        <a href="#" class="footer-link">Polityka prywatności</a>
        <a href="#" class="footer-link">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { background: #0f172a; color: #fff; }

  .footer-top {
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1rem;
  }
  @media (min-width: 640px) { .footer-top { padding: 4rem 1.5rem; } }
  @media (min-width: 1024px) { .footer-top { padding: 5rem 2rem; } }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 640px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: repeat(5, 1fr); gap: 2rem; }
  }

  .footer-brand { grid-column: auto; }
  @media (min-width: 1024px) { .footer-brand { grid-column: span 2; } }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  .footer-logo-bg {
    display: flex;
    padding: 0.5rem;
    background: var(--sky);
    border-radius: 0.75rem;
  }
  .footer-logo-ico { width: 1.5rem; height: 1.5rem; color: #fff; }
  .footer-logo-text { display: flex; flex-direction: column; }
  .footer-logo-name { font-size: 1.25rem; font-weight: 700; color: #fff; }
  .footer-logo-sub {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #38bdf8;
  }

  .footer-desc {
    color: #94a3b8;
    margin-bottom: 1.5rem;
    line-height: 1.7;
    max-width: 28rem;
  }

  .footer-social { display: flex; align-items: center; gap: 1rem; }
  .footer-social-link {
    display: flex;
    padding: 0.5rem;
    background: #1e293b;
    border-radius: 0.5rem;
    color: #fff;
    transition: background 0.2s ease;
  }
  .footer-social-link:hover { background: var(--sky); }
  .footer-social-ico { width: 1.25rem; height: 1.25rem; }

  .footer-heading {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .footer-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-link {
    color: #94a3b8;
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #38bdf8; }

  .footer-mail { display: flex; align-items: center; gap: 0.75rem; }
  .footer-mail-ico { width: 1.25rem; height: 1.25rem; color: var(--sky); flex-shrink: 0; }
  .footer-mail-text { word-break: break-all; }

  .footer-bottom { border-top: 1px solid #1e293b; }
  .footer-bottom-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .footer-bottom-inner { flex-direction: row; text-align: left; }
  }
  @media (min-width: 640px) { .footer-bottom-inner { padding: 1.5rem; } }
  @media (min-width: 1024px) { .footer-bottom-inner { padding: 1.5rem 2rem; } }

  .footer-copy { color: #64748b; font-size: 0.875rem; }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  @media (min-width: 768px) { .footer-legal { gap: 1.5rem; } }
  .footer-legal .footer-link { font-size: 0.875rem; color: #64748b; }
  .footer-legal .footer-link:hover { color: #38bdf8; }
</style>
