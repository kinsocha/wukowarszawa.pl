---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';
import { districts, type DistrictData } from '../data/districts';

interface Props {
  district: DistrictData;
}

const { district } = Astro.props;
const others = siteConfig.mainDistricts.filter(n => n !== district.name);
---

<!-- Hero -->
<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 bg-gradient-to-br from-slate-900 via-slate-800 to-sky-900 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-sky-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay:1s"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2 text-white/60 text-sm mb-6">
      <a href="/" class="hover:text-sky-300 transition-colors">Strona główna</a>
      <span>/</span>
      <span class="text-white">{district.fullName}</span>
    </div>
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
        <Icon name="map-pin" class="w-4 h-4 text-sky-300" />
        <span class="text-white/90 text-sm font-medium">Warszawa, dzielnica {district.name}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {district.fullName}
        <span class="block bg-gradient-to-r from-sky-400 to-cyan-400 bg-clip-text text-transparent">
          udrażnianie kanalizacji
        </span>
      </h1>
      <p class="text-lg sm:text-xl text-white/80 max-w-3xl mb-10 leading-relaxed">{district.heroIntro}</p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="group flex items-center gap-3 bg-gradient-to-r from-sky-500 to-cyan-500 text-white px-8 py-4 rounded-full text-lg font-semibold hover:shadow-xl hover:shadow-sky-500/40 transition-all hover:scale-105"
        >
          <Icon name="phone" class="w-5 h-5" />
          <span>Zadzwoń: {siteConfig.phone}</span>
        </a>
        <a href="#zakres-prac" class="flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white/20 transition-all">
          Zobacz, w czym pomagamy
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Opis -->
<section class="py-20 lg:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">
      Czyszczenie kanalizacji w dzielnicy {district.name}
    </h2>
    <p class="text-lg text-slate-600 leading-relaxed mb-6">{district.description}</p>
    <p class="text-lg text-slate-600 leading-relaxed">
      Przed przyjazdem prosimy o krótki opis objawów i rodzaju budynku. Ułatwia to dobór sprzętu
      (Wuko lub sprężyna mechaniczna) i pozwala lepiej oszacować zakres prac na miejscu.
    </p>
  </div>
</section>

<!-- Zakres prac -->
<section id="zakres-prac" class="py-20 lg:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Co robimy w {district.name}</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Zakres prac</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { icon: 'droplets', title: 'Hydrodynamiczne Wuko', desc: 'Czyszczenie rur wodą pod wysokim ciśnieniem (do 200 bar). Skuteczne przy osadach, tłuszczach i zalegających zanieczyszczeniach.' },
        { icon: 'wrench',   title: 'Sprężyna elektryczna', desc: 'Mechaniczne usuwanie zatorów w pionach, poziomach i przy zlewach, umywalkach, toaletach.' },
        { icon: 'camera',   title: 'Inspekcja kamerą TV',  desc: 'Diagnostyka wnętrza rur kamerą o wysokiej rozdzielczości. Lokalizacja uszkodzeń, załamań, korzeni.' },
      ].map(item => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
          <div class="p-3 bg-sky-50 rounded-xl w-fit mb-4">
            <Icon name={item.icon} class="w-7 h-7 text-sky-600" />
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
          <p class="text-slate-600 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Obszar działania -->
<section class="py-20 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Obsługujemy</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{district.name} – obszar działania</h2>
    </div>
    <div class="mb-12">
      <h3 class="text-xl font-semibold text-slate-700 mb-4">Osiedla i części dzielnicy:</h3>
      <div class="flex flex-wrap gap-3">
        {district.areas.map(a => (
          <span class="px-4 py-2 bg-sky-50 text-sky-700 rounded-full font-medium border border-sky-100">{a}</span>
        ))}
      </div>
    </div>
    <div>
      <h3 class="text-xl font-semibold text-slate-700 mb-4">Dojeżdżamy m.in. na ulice:</h3>
      <p class="text-slate-600 leading-relaxed">
        {district.streets.join(' • ')} i pozostałe ulice dzielnicy {district.name}.
      </p>
    </div>
  </div>
</section>

<!-- Opinie lokalne -->
{district.testimonials.length > 0 && (
  <section class="py-20 lg:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Opinie z {district.name}</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Co mówią klienci</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {district.testimonials.map(t => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <Icon name="quote" class="w-8 h-8 text-sky-300 mb-4" />
            <p class="text-slate-700 leading-relaxed mb-4 italic">"{t.text}"</p>
            <div class="flex items-center gap-2 text-sm text-slate-500">
              <Icon name="map-pin" class="w-4 h-4" />
              <span>{t.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Dlaczego my -->
<section class="py-20 lg:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-12 text-center">Dlaczego warto wybrać nas w {district.name}</h2>
    <div class="space-y-4">
      {[
        `Doświadczenie od ${siteConfig.experienceSince} r. – praca z kanalizacją miejską (MPWiK Warszawa) i przydomową`,
        'Sprzęt dopasowany do bloków, kamienic i domów jednorodzinnych',
        'Jasne zasady rozliczeń i możliwość faktury VAT',
        'Skupienie na usunięciu przyczyny problemu, nie tylko jego skutków',
        'Dobra znajomość dzielnicy – szybki dojazd i sprawne wykonanie',
      ].map(p => (
        <div class="flex items-start gap-3">
          <Icon name="check-circle" class="w-6 h-6 text-sky-500 flex-shrink-0 mt-0.5" />
          <p class="text-lg text-slate-700">{p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Breadcrumb JSON-LD -->
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: siteConfig.url + '/' },
    { '@type': 'ListItem', position: 2, name: district.fullName, item: siteConfig.url + '/' + district.slug },
  ],
})} />

<!-- FAQ -->
{district.faq && district.faq.length > 0 && (
  <>
    <Fragment set:html={'<script type="application/ld+json">' + JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": district.faq.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer }
      }))
    }) + '</script>'} />
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Pytania i odpowiedzi</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">FAQ – Wuko {district.name}</h2>
        </div>
        <div class="space-y-4">
          {district.faq.map(f => (
            <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
              <h3 class="text-lg font-bold text-slate-900 mb-3">{f.question}</h3>
              <p class="text-slate-600 leading-relaxed">{f.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </>
)}

<!-- CTA -->
<section class="py-16 lg:py-20 bg-gradient-to-br from-sky-600 to-cyan-600">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Potrzebujesz Wuko w {district.name}?</h2>
    <p class="text-xl text-white/90 mb-8">Zadzwoń – ustalimy termin i orientacyjny koszt.</p>
    <a
      href={`tel:${siteConfig.phoneTel}`}
      class="inline-flex items-center gap-3 bg-white text-sky-600 px-10 py-5 rounded-full text-xl font-bold hover:shadow-2xl transition-all hover:scale-105"
    >
      <Icon name="phone" class="w-6 h-6" />
      <span>{siteConfig.phone}</span>
    </a>
  </div>
</section>

<!-- Inne dzielnice -->
<section class="py-16 lg:py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-slate-900 mb-8 text-center">Działamy też w innych dzielnicach Warszawy</h2>
    <div class="flex flex-wrap justify-center gap-3">
      {others.map(name => {
        const d = districts.find(x => x.name === name);
        if (!d) return null;
        return (
          <a
            href={`/${d.slug}`}
            class="group flex items-center gap-2 bg-white px-5 py-3 rounded-full border border-slate-200 hover:border-sky-300 hover:shadow-md transition-all"
          >
            <Icon name="map-pin" class="w-4 h-4 text-sky-500" />
            <span class="font-medium text-slate-700 group-hover:text-sky-600">Wuko {name}</span>
            <Icon name="arrow-right" class="w-4 h-4 text-slate-300 group-hover:text-sky-500 group-hover:translate-x-1 transition-all" />
          </a>
        );
      })}
    </div>
  </div>
</section>
