---
import Icon from './Icon.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('poradnik'))
  .filter(({ data }) => data.pubDate.valueOf() <= Date.now())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatter = new Intl.DateTimeFormat('pl-PL', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<section id="poradnik" class="py-20 lg:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Poradnik</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
        Porady z codziennej pracy
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Odpowiadamy na pytania, które słyszymy od klientów najczęściej — o ceny,
        dobór metody i profilaktykę.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-12">
      {articles.map(article => (
        <article class="group bg-white rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl hover:shadow-sky-500/10 hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="h-1.5 bg-gradient-to-r from-sky-500 to-cyan-500"></div>
          <div class="p-6 lg:p-8 flex flex-col flex-1">
            <div class="flex items-center gap-3 text-sm mb-4">
              <span class="inline-block bg-sky-50 text-sky-700 font-semibold px-3 py-1 rounded-full">
                {article.data.category}
              </span>
              <time class="text-slate-500" datetime={article.data.pubDate.toISOString()}>
                {formatter.format(article.data.pubDate)}
              </time>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 leading-snug">
              <a href={`/poradnik/${article.slug}/`} class="hover:text-sky-700 transition-colors">
                {article.data.title}
              </a>
            </h3>
            <p class="text-slate-600 leading-relaxed mb-6 flex-1">{article.data.description}</p>
            <a
              href={`/poradnik/${article.slug}/`}
              class="inline-flex items-center text-sky-600 font-semibold group-hover:text-sky-700"
            >
              Czytaj
              <Icon name="arrow-right" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center">
      <a
        href="/poradnik/"
        class="inline-flex items-center gap-2 bg-gradient-to-r from-sky-500 to-cyan-500 text-white px-8 py-3.5 rounded-full font-semibold hover:shadow-lg hover:shadow-sky-500/30 transition-all hover:scale-105"
      >
        Zobacz wszystkie porady
        <Icon name="arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>
