---
import Icon from './Icon.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('poradnik'))
  .filter(({ data }) => data.pubDate.valueOf() <= Date.now())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatter = new Intl.DateTimeFormat('pl-PL', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<section id="poradnik" class="ps">
  <div class="ps-inner">
    <div class="ps-head">
      <span class="eyebrow">Poradnik</span>
      <h2 class="ps-title">Porady z codziennej pracy</h2>
      <p class="ps-sub">
        Odpowiadamy na pytania, które słyszymy od klientów najczęściej — o ceny,
        dobór metody i profilaktykę.
      </p>
    </div>

    <div class="ps-grid">
      {articles.map(article => (
        <article class="ps-card">
          <div class="ps-card-bar"></div>
          <div class="ps-card-body">
            <div class="ps-meta">
              <span class="ps-cat">{article.data.category}</span>
              <time class="ps-date" datetime={article.data.pubDate.toISOString()}>
                {formatter.format(article.data.pubDate)}
              </time>
            </div>
            <h3 class="ps-card-title">
              <a href={`/poradnik/${article.slug}/`}>{article.data.title}</a>
            </h3>
            <p class="ps-card-desc">{article.data.description}</p>
            <a href={`/poradnik/${article.slug}/`} class="ps-read">
              Czytaj
              <Icon name="arrow-right" class="ps-read-ico" />
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="ps-cta-wrap">
      <a href="/poradnik/" class="ps-cta">
        Zobacz wszystkie porady
        <Icon name="arrow-right" class="ps-cta-ico" />
      </a>
    </div>
  </div>
</section>

<style>
  .ps { padding: 5rem 0; background: var(--bg-light); }
  @media (min-width: 1024px) { .ps { padding: 7rem 0; } }

  .ps-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .ps-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .ps-inner { padding: 0 2rem; } }

  .ps-head { text-align: center; margin-bottom: 3.5rem; }
  .eyebrow {
    display: inline-block;
    color: #0284c7;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .ps-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .ps-title { font-size: 2.25rem; } }
  @media (min-width: 1024px) { .ps-title { font-size: 3rem; } }
  .ps-sub { font-size: 1.125rem; color: #475569; max-width: 42rem; margin: 0 auto; }

  .ps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 768px) { .ps-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ps-grid { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }

  .ps-card {
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    border: 1px solid #f1f5f9;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .ps-card:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 20px 40px rgba(14, 165, 233, 0.1);
  }
  .ps-card-bar { height: 0.375rem; background: linear-gradient(90deg, var(--sky), var(--cyan)); }
  .ps-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  @media (min-width: 1024px) { .ps-card-body { padding: 2rem; } }

  .ps-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; margin-bottom: 1rem; }
  .ps-cat {
    display: inline-block;
    background: var(--bg-sky);
    color: #0369a1;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }
  .ps-date { color: #64748b; }

  .ps-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }
  .ps-card-title a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .ps-card-title a:hover { color: #0369a1; }
  .ps-card-desc { color: #475569; line-height: 1.7; margin-bottom: 1.5rem; flex: 1; }

  .ps-read {
    display: inline-flex;
    align-items: center;
    color: #0284c7;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ps-card:hover .ps-read { color: #0369a1; }
  .ps-read-ico { width: 1rem; height: 1rem; margin-left: 0.5rem; transition: transform 0.25s ease; }
  .ps-card:hover .ps-read-ico { transform: translateX(0.25rem); }

  .ps-cta-wrap { text-align: center; }
  .ps-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(90deg, var(--sky), var(--cyan));
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .ps-cta:hover { transform: scale(1.05); box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3); }
  .ps-cta-ico { width: 1rem; height: 1rem; }
</style>
