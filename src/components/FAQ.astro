---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const faqs = [
  {
    question: 'Co to jest wuko?',
    answer: 'Wuko to ciśnieniowe (hydrodynamiczne) czyszczenie kanalizacji. Głowica na wężu podaje do rury wodę pod ciśnieniem nawet 200 bar, a strumień zrywa ze ścianek tłuszcz, osady i kamień. Zerwany brud spływa do studzienki – bez chemii i bez kucia ścian.',
  },
  {
    question: 'Ile kosztuje udrażnianie kanalizacji?',
    answer: 'Ceny zależą od rodzaju instalacji, dostępu do rur i skali problemu. Orientacyjne stawki dla poszczególnych usług zebraliśmy w sekcji Cennik na tej stronie. Dokładną wycenę zawsze podajemy przed przyjazdem – wystarczy krótki opis problemu.',
  },
  {
    question: 'Czy zatkany zlew można udrożnić samemu?',
    answer: 'Pierwszym krokiem nie musi być od razu telefon po Wuko. Bezpiecznym działaniem jest zdjęcie syfonu i jego dokładne wyczyszczenie oraz przelanie instalacji gorącą wodą. Pomóc może też zwykła ręczna przepychaczka. Często powtarzane „patenty" z sodą i octem w praktyce nie rozwiązują zatoru – wtedy warto zadzwonić.',
  },
  {
    question: 'Jaka jest różnica między Wuko a sprężyną?',
    answer: 'Wuko (czyszczenie hydrodynamiczne) to woda pod wysokim ciśnieniem – do 200 bar. Świetnie usuwa tłuszcz, osady mineralne i organiczne, kamień. Sprężyna elektryczna to mechaniczne rozbijanie zatoru – sprawdza się przy włosach, resztkach jedzenia, papierze. Dobieramy metodę do problemu po obejrzeniu instalacji.',
  },
  {
    question: 'Czy metoda Wuko jest bezpieczna dla rur?',
    answer: 'Tak. Hydrodynamiczne Wuko jest bezpieczne dla wszystkich typowych instalacji kanalizacyjnych – PVC, kamionka, żeliwo. Ciśnienie regulujemy do typu rury i średnicy. Metoda nie wymaga rozkuwania ścian i nie używamy agresywnej chemii.',
  },
  {
    question: 'Gdzie dokładnie działacie?',
    answer: 'Cała Warszawa i okolice. Dojeżdżamy m.in. na Pragę, Bielany, Mokotów, Ursynów, Wolę, Bemowo, Białołękę, Targówek, Wawer, Ochotę, Ursus, Rembertów i okoliczne gminy. Najlepiej zadzwonić i podać dokładny adres.',
  },
  {
    question: 'Czy wystawiacie fakturę VAT?',
    answer: 'Tak. Wystawiamy faktury VAT dla firm, wspólnot mieszkaniowych i klientów indywidualnych. Można umówić się na cyklicznie powtarzane prace – np. okresową konserwację pionów w budynku.',
  },
  {
    question: 'Co jeśli problem wróci?',
    answer: 'Po pracy zostawiamy porządek i przekazujemy wskazówki na przyszłość. Jeśli mimo to zator wraca, zwykle oznacza to głębsze problemy z instalacją (uszkodzenie, wrastające korzenie, zła geometria rur). Wtedy warto wykonać inspekcję kamerą TV.',
  },
  {
    question: 'Jak szybko możecie przyjechać?',
    answer: `Zawsze ustalamy termin przed przyjazdem. Często udaje się dojechać tego samego dnia, w pilnych sytuacjach staramy się reagować priorytetowo. Zadzwoń: ${siteConfig.phone} – podamy najszybszy realny termin.`,
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
});
---

<script type="application/ld+json" is:inline set:html={faqSchema} />
<section class="faq">
  <div class="faq-inner">
    <div class="faq-head">
      <span class="eyebrow">FAQ</span>
      <h2 class="faq-title">Najczęstsze pytania</h2>
      <p class="faq-sub">Krótko i konkretnie. Jeśli nie znajdziesz odpowiedzi – po prostu zadzwoń.</p>
    </div>

    <div class="faq-box">
      {faqs.map((faq, i) => (
        <div class:list={['faq-item', i === 0 && 'is-open']}>
          <button class="faq-btn" data-index={i}>
            <span class="faq-q">{faq.question}</span>
            <span class="faq-icon">
              <Icon name="plus" class="icon-open" />
              <Icon name="minus" class="icon-close" />
            </span>
          </button>
          <div class="faq-content">
            <p class="faq-a">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding: 5rem 0; background: #fff; }
  @media (min-width: 1024px) { .faq { padding: 7rem 0; } }

  .faq-inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .faq-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .faq-inner { padding: 0 2rem; } }

  .faq-head { text-align: center; margin-bottom: 4rem; }
  .eyebrow {
    display: inline-block;
    color: #0284c7;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .faq-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .faq-title { font-size: 2.25rem; } }
  @media (min-width: 1024px) { .faq-title { font-size: 3rem; } }
  .faq-sub { font-size: 1.125rem; color: #475569; }

  .faq-box {
    background: var(--bg-light);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  @media (min-width: 1024px) { .faq-box { padding: 2rem; } }

  .faq-item { border-bottom: 1px solid #e2e8f0; }
  .faq-item:last-child { border-bottom: none; }

  .faq-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .faq-btn:hover { color: #0284c7; }
  .faq-q { font-size: 1.125rem; font-weight: 600; color: #0f172a; padding-right: 1rem; }
  .faq-btn:hover .faq-q { color: #0284c7; }

  .faq-icon {
    flex-shrink: 0;
    display: flex;
    padding: 0.5rem;
    border-radius: 50%;
    background: #f1f5f9;
    color: #64748b;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .faq-item.is-open .faq-icon { background: #e0f2fe; color: #0284c7; }
  .faq-icon :global(svg) { width: 1.25rem; height: 1.25rem; }
  .faq-icon :global(.icon-close) { display: none; }
  .faq-item.is-open .faq-icon :global(.icon-open) { display: none; }
  .faq-item.is-open .faq-icon :global(.icon-close) { display: block; }

  .faq-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }
  .faq-item.is-open .faq-content { max-height: 24rem; padding-bottom: 1.25rem; }
  .faq-a { color: #475569; line-height: 1.7; }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.faq-item');

  items.forEach(item => {
    const btn = item.querySelector<HTMLElement>('.faq-btn')!;
    btn.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');
      items.forEach(it => it.classList.remove('is-open'));
      if (!isOpen) item.classList.add('is-open');
    });
  });
</script>
