---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const serviceOptions = [
  'Hydrodynamiczne Wuko',
  'Sprężyna elektryczna',
  'Inspekcja kamerą TV',
  'Mieszkanie / dom jednorodzinny',
  'Wspólnota mieszkaniowa / blok',
  'Lokal usługowy / firma',
  'Inne / nie wiem',
];
---

<section id="kontakt" class="py-20 lg:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Kontakt</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">Zadzwoń lub napisz</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Najszybciej zadzwonić – ustalimy termin i podamy orientacyjny koszt.
        Możesz też zostawić wiadomość przez formularz.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Form -->
      <div class="bg-white rounded-2xl p-6 lg:p-10 shadow-sm">
        <!-- Success -->
        <div id="form-success" class="hidden text-center py-12">
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <Icon name="check-circle" class="w-10 h-10 text-green-500" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">Dziękujemy za wiadomość!</h3>
          <p class="text-slate-600 mb-6">Skontaktujemy się z Tobą najszybciej, jak to możliwe.</p>
          <button id="send-another" class="text-sky-600 font-semibold hover:text-sky-700 transition-colors">
            Wyślij kolejną wiadomość
          </button>
        </div>

        <!-- Form fields -->
        <form id="contact-form" class="space-y-6">
          {[
            { id: 'name',    label: 'Imię i nazwisko *',    type: 'text',  placeholder: 'Jan Kowalski',        required: true },
            { id: 'phone',   label: 'Telefon *',             type: 'tel',   placeholder: siteConfig.phone,      required: true },
            { id: 'email',   label: 'E-mail (opcjonalnie)',  type: 'email', placeholder: 'jan@example.pl',      required: false },
          ].map(f => (
            <div>
              <label for={f.id} class="block text-sm font-medium text-slate-700 mb-2">{f.label}</label>
              <input
                type={f.type}
                id={f.id}
                name={f.id}
                placeholder={f.placeholder}
                class="form-field w-full px-4 py-3 rounded-xl border border-slate-200 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500"
              />
              <p id={`${f.id}-error`} class="form-error hidden mt-1 text-sm text-red-500 flex items-center gap-1">
                <Icon name="alert-circle" class="w-4 h-4" />
                <span></span>
              </p>
            </div>
          ))}

          <div>
            <label for="service" class="block text-sm font-medium text-slate-700 mb-2">Rodzaj sprawy *</label>
            <select
              id="service"
              name="service"
              class="form-field w-full px-4 py-3 rounded-xl border border-slate-200 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500 bg-white"
            >
              <option value="">Wybierz...</option>
              {serviceOptions.map(o => <option value={o}>{o}</option>)}
            </select>
            <p id="service-error" class="form-error hidden mt-1 text-sm text-red-500 flex items-center gap-1">
              <Icon name="alert-circle" class="w-4 h-4" />
              <span></span>
            </p>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Krótki opis problemu *</label>
            <textarea
              id="message"
              name="message"
              rows={4}
              placeholder="Np. zatkany zlew kuchenny, mieszkanie w bloku, Praga Południe..."
              class="form-field w-full px-4 py-3 rounded-xl border border-slate-200 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-sky-500 resize-none"
            ></textarea>
            <p id="message-error" class="form-error hidden mt-1 text-sm text-red-500 flex items-center gap-1">
              <Icon name="alert-circle" class="w-4 h-4" />
              <span></span>
            </p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-gradient-to-r from-sky-500 to-cyan-500 text-white py-3.5 rounded-full font-semibold hover:shadow-lg hover:shadow-sky-500/30 transition-all flex items-center justify-center gap-2"
          >
            <Icon name="send" class="w-5 h-5" />
            <span>Wyślij wiadomość</span>
          </button>
        </form>
      </div>

      <!-- Info -->
      <div class="space-y-6">
        <div class="bg-gradient-to-br from-sky-500 to-cyan-500 rounded-2xl p-8 text-white">
          <h3 class="text-2xl font-bold mb-3">Najszybciej – telefon</h3>
          <p class="mb-6 text-white/90">Krótki opis problemu, dzielnica i typ budynku – w 2 minuty wiemy, co przygotować.</p>
          <a
            href={`tel:${siteConfig.phoneTel}`}
            class="inline-flex items-center gap-3 bg-white text-sky-600 px-6 py-3 rounded-full font-bold hover:shadow-xl transition-all hover:scale-105"
          >
            <Icon name="phone" class="w-5 h-5" />
            <span>{siteConfig.phone}</span>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl p-5 shadow-sm">
            <div class="p-2 bg-sky-50 rounded-lg w-fit mb-3">
              <Icon name="mail" class="w-5 h-5 text-sky-600" />
            </div>
            <div class="font-semibold text-slate-900 mb-1">E-mail</div>
            <a href={`mailto:${siteConfig.email}`} class="text-slate-600 hover:text-sky-600 transition-colors text-sm">{siteConfig.email}</a>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-sm">
            <div class="p-2 bg-sky-50 rounded-lg w-fit mb-3">
              <Icon name="clock" class="w-5 h-5 text-sky-600" />
            </div>
            <div class="font-semibold text-slate-900 mb-1">Termin realizacji</div>
            <div class="text-slate-600 text-sm">Zawsze ustalamy przed przyjazdem</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form        = document.getElementById('contact-form') as HTMLFormElement;
  const success     = document.getElementById('form-success') as HTMLElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
  const sendAnother = document.getElementById('send-another') as HTMLButtonElement;

  function showError(field: string, msg: string) {
    const el  = document.getElementById(`${field}-error`) as HTMLElement;
    const inp = document.getElementById(field) as HTMLElement;
    if (el) { el.classList.remove('hidden'); el.querySelector('span')!.textContent = msg; }
    inp?.classList.add('border-red-300');
  }

  function clearErrors() {
    document.querySelectorAll<HTMLElement>('.form-error').forEach(e => e.classList.add('hidden'));
    document.querySelectorAll<HTMLElement>('.form-field').forEach(f => f.classList.remove('border-red-300'));
  }

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    clearErrors();

    const data = Object.fromEntries(new FormData(form)) as Record<string, string>;
    let valid = true;

    if (!data.name?.trim())  { showError('name',    'Imię i nazwisko jest wymagane'); valid = false; }
    if (!data.phone?.trim()) { showError('phone',   'Numer telefonu jest wymagany'); valid = false; }
    else if (!/^[0-9\s+()-]{9,}$/.test(data.phone)) { showError('phone', 'Podaj prawidłowy numer telefonu'); valid = false; }
    if (data.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { showError('email', 'Podaj prawidłowy adres e-mail'); valid = false; }
    if (!data.service)       { showError('service', 'Wybierz rodzaj usługi'); valid = false; }
    if (!data.message?.trim()){ showError('message', 'Opisz swój problem'); valid = false; }

    if (!valid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wysyłanie...';

    await new Promise(r => setTimeout(r, 1500));

    form.classList.add('hidden');
    success.classList.remove('hidden');
  });

  sendAnother?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    success.classList.add('hidden');
    submitBtn.disabled = false;
    submitBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m22 2-7 20-4-9-9-4 20-7z"/><path d="M22 2 11 13"/></svg><span>Wyślij wiadomość</span>';
  });
</script>
