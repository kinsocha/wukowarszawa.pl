---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';

const serviceOptions = [
  'Hydrodynamiczne Wuko',
  'Sprężyna elektryczna',
  'Inspekcja kamerą TV',
  'Mieszkanie / dom jednorodzinny',
  'Wspólnota mieszkaniowa / blok',
  'Lokal usługowy / firma',
  'Inne / nie wiem',
];

const fields = [
  { id: 'name',  label: 'Imię i nazwisko *',   type: 'text',  placeholder: 'Jan Kowalski',   required: true },
  { id: 'phone', label: 'Telefon *',            type: 'tel',   placeholder: siteConfig.phone, required: true },
  { id: 'email', label: 'E-mail (opcjonalnie)', type: 'email', placeholder: 'jan@example.pl', required: false },
];
---

<section id="kontakt" class="contact">
  <div class="contact-inner">
    <div class="contact-head">
      <span class="eyebrow">Kontakt</span>
      <h2 class="contact-title">Zadzwoń lub napisz</h2>
      <p class="contact-sub">
        Najszybciej zadzwonić – ustalimy termin i podamy orientacyjny koszt.
        Możesz też zostawić wiadomość przez formularz.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Form -->
      <div class="contact-form-card">
        <div id="form-success" class="form-success u-hidden">
          <div class="success-ico-wrap">
            <Icon name="check-circle" class="success-ico" />
          </div>
          <h3 class="success-title">Dziękujemy za wiadomość!</h3>
          <p class="success-text">Skontaktujemy się z Tobą najszybciej, jak to możliwe.</p>
          <button id="send-another" class="success-btn">Wyślij kolejną wiadomość</button>
        </div>

        <form id="contact-form" class="contact-form">
          {fields.map(f => (
            <div class="field">
              <label for={f.id} class="field-label">{f.label}</label>
              <input type={f.type} id={f.id} name={f.id} placeholder={f.placeholder} class="form-field" />
              <p id={`${f.id}-error`} class="form-error u-hidden">
                <Icon name="alert-circle" class="err-ico" />
                <span></span>
              </p>
            </div>
          ))}

          <div class="field">
            <label for="service" class="field-label">Rodzaj sprawy *</label>
            <select id="service" name="service" class="form-field form-select">
              <option value="">Wybierz...</option>
              {serviceOptions.map(o => <option value={o}>{o}</option>)}
            </select>
            <p id="service-error" class="form-error u-hidden">
              <Icon name="alert-circle" class="err-ico" />
              <span></span>
            </p>
          </div>

          <div class="field">
            <label for="message" class="field-label">Krótki opis problemu *</label>
            <textarea
              id="message"
              name="message"
              rows={4}
              placeholder="Np. zatkany zlew kuchenny, mieszkanie w bloku, Praga Południe..."
              class="form-field form-textarea"
            ></textarea>
            <p id="message-error" class="form-error u-hidden">
              <Icon name="alert-circle" class="err-ico" />
              <span></span>
            </p>
          </div>

          <button type="submit" id="submit-btn" class="submit-btn">
            <Icon name="send" class="submit-ico" />
            <span>Wyślij wiadomość</span>
          </button>
        </form>
      </div>

      <!-- Info -->
      <div class="contact-info">
        <div class="info-phone-card">
          <h3 class="info-phone-title">Najszybciej – telefon</h3>
          <p class="info-phone-text">Krótki opis problemu, dzielnica i typ budynku – w 2 minuty wiemy, co przygotować.</p>
          <a href={`tel:${siteConfig.phoneTel}`} class="info-phone-btn">
            <Icon name="phone" class="info-phone-ico" />
            <span>{siteConfig.phone}</span>
          </a>
        </div>

        <div class="info-cards">
          <div class="info-card">
            <div class="info-card-ico-wrap">
              <Icon name="mail" class="info-card-ico" />
            </div>
            <div class="info-card-label">E-mail</div>
            <a href={`mailto:${siteConfig.email}`} class="info-card-link">{siteConfig.email}</a>
          </div>
          <div class="info-card">
            <div class="info-card-ico-wrap">
              <Icon name="clock" class="info-card-ico" />
            </div>
            <div class="info-card-label">Termin realizacji</div>
            <div class="info-card-meta">Zawsze ustalamy przed przyjazdem</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact { padding: 5rem 0; background: var(--bg-light); }
  @media (min-width: 1024px) { .contact { padding: 7rem 0; } }

  .contact-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .contact-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .contact-inner { padding: 0 2rem; } }

  .contact-head { text-align: center; margin-bottom: 4rem; }
  .eyebrow {
    display: inline-block;
    color: #0284c7;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .contact-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .contact-title { font-size: 2.25rem; } }
  @media (min-width: 1024px) { .contact-title { font-size: 3rem; } }
  .contact-sub { font-size: 1.125rem; color: #475569; max-width: 42rem; margin: 0 auto; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) { .contact-grid { grid-template-columns: repeat(2, 1fr); gap: 4rem; } }

  /* Form */
  .contact-form-card {
    background: #fff;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
  @media (min-width: 1024px) { .contact-form-card { padding: 2.5rem; } }

  .form-success { text-align: center; padding: 3rem 0; }
  .success-ico-wrap {
    width: 5rem;
    height: 5rem;
    background: #dcfce7;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .success-ico { width: 2.5rem; height: 2.5rem; color: #22c55e; }
  .success-title { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 1rem; }
  .success-text { color: #475569; margin-bottom: 1.5rem; }
  .success-btn {
    background: none;
    border: none;
    color: #0284c7;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .success-btn:hover { color: #0369a1; }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .field-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: #334155;
    margin-bottom: 0.5rem;
  }
  .form-field {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    font-family: inherit;
    font-size: 1rem;
    color: #334155;
    background: #fff;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-field:focus {
    outline: none;
    border-color: var(--sky);
    box-shadow: 0 0 0 2px rgba(14, 165, 233, 0.5);
  }
  .form-field.is-invalid { border-color: #fca5a5; }
  .form-textarea { resize: none; }

  .form-error {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: #ef4444;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .err-ico { width: 1rem; height: 1rem; }

  .submit-btn {
    width: 100%;
    background: linear-gradient(90deg, var(--sky), var(--cyan));
    color: #fff;
    padding: 0.875rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: box-shadow 0.25s ease;
  }
  .submit-btn:hover { box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3); }
  .submit-ico { width: 1.25rem; height: 1.25rem; }

  /* Info */
  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-phone-card {
    background: linear-gradient(135deg, var(--sky), var(--cyan));
    border-radius: 1rem;
    padding: 2rem;
    color: #fff;
  }
  .info-phone-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; }
  .info-phone-text { margin-bottom: 1.5rem; color: rgba(255, 255, 255, 0.9); }
  .info-phone-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #fff;
    color: #0284c7;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .info-phone-btn:hover { transform: scale(1.05); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15); }
  .info-phone-ico { width: 1.25rem; height: 1.25rem; }

  .info-cards { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 640px) { .info-cards { grid-template-columns: repeat(2, 1fr); } }
  .info-card {
    background: #fff;
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
  .info-card-ico-wrap {
    padding: 0.5rem;
    background: var(--bg-sky);
    border-radius: 0.5rem;
    width: fit-content;
    margin-bottom: 0.75rem;
  }
  .info-card-ico { width: 1.25rem; height: 1.25rem; color: #0284c7; }
  .info-card-label { font-weight: 600; color: #0f172a; margin-bottom: 0.25rem; }
  .info-card-link {
    color: #475569;
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .info-card-link:hover { color: #0284c7; }
  .info-card-meta { color: #475569; font-size: 0.875rem; }
</style>

<script>
  const form        = document.getElementById('contact-form') as HTMLFormElement;
  const success     = document.getElementById('form-success') as HTMLElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
  const sendAnother = document.getElementById('send-another') as HTMLButtonElement;

  function showError(field: string, msg: string) {
    const el  = document.getElementById(`${field}-error`) as HTMLElement;
    const inp = document.getElementById(field) as HTMLElement;
    if (el) { el.classList.remove('u-hidden'); el.querySelector('span')!.textContent = msg; }
    inp?.classList.add('is-invalid');
  }

  function clearErrors() {
    document.querySelectorAll<HTMLElement>('.form-error').forEach(e => e.classList.add('u-hidden'));
    document.querySelectorAll<HTMLElement>('.form-field').forEach(f => f.classList.remove('is-invalid'));
  }

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    clearErrors();

    const data = Object.fromEntries(new FormData(form)) as Record<string, string>;
    let valid = true;

    if (!data.name?.trim())  { showError('name',    'Imię i nazwisko jest wymagane'); valid = false; }
    if (!data.phone?.trim()) { showError('phone',   'Numer telefonu jest wymagany'); valid = false; }
    else if (!/^[0-9\s+()-]{9,}$/.test(data.phone)) { showError('phone', 'Podaj prawidłowy numer telefonu'); valid = false; }
    if (data.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { showError('email', 'Podaj prawidłowy adres e-mail'); valid = false; }
    if (!data.service)       { showError('service', 'Wybierz rodzaj usługi'); valid = false; }
    if (!data.message?.trim()){ showError('message', 'Opisz swój problem'); valid = false; }

    if (!valid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wysyłanie...';

    await new Promise(r => setTimeout(r, 1500));

    form.classList.add('u-hidden');
    success.classList.remove('u-hidden');
  });

  sendAnother?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('u-hidden');
    success.classList.add('u-hidden');
    submitBtn.disabled = false;
    submitBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="submit-ico"><path d="m22 2-7 20-4-9-9-4 20-7z"/><path d="M22 2 11 13"/></svg><span>Wyślij wiadomość</span>';
  });
</script>
