---
import { iconPaths } from '../utils/icons';

interface Props {
  name: string;
  size?: number;
  class?: string;
  id?: string;
}

const { name, size = 24, class: className = '', id } = Astro.props;
const paths = iconPaths[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  id={id}
  set:html={paths}
></svg>
