---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';
import { districts } from '../data/districts';

const withPages = districts.map(d => d.name);
const withoutPages = siteConfig.allDistricts.filter(d => !withPages.includes(d));
---

<section class="py-20 lg:py-28 bg-gradient-to-br from-sky-50 to-cyan-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block text-sky-600 font-semibold text-sm tracking-wider uppercase mb-4">Obsługujemy</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">Cała Warszawa i okolice</h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">
        Dojeżdżamy m.in. na Pragę, Bielany, Mokotów, Ursynów, Wolę, Bemowo, Białołękę, Targówek,
        Rembertów i okoliczne gminy. Najlepiej zadzwonić i podać dokładny adres.
      </p>
    </div>

    <div class="mb-12">
      <h3 class="text-xl font-bold text-slate-900 mb-6 text-center flex items-center justify-center gap-2">
        <Icon name="star" class="w-5 h-5 text-amber-500 fill-amber-500" />
        Dzielnice z osobnymi stronami
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {districts.map(d => (
          <a
            href={`/${d.slug}`}
            class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all"
          >
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="p-2 bg-sky-100 rounded-lg group-hover:bg-sky-500 transition-colors">
                  <Icon name="map-pin" class="w-5 h-5 text-sky-600 group-hover:text-white transition-colors" />
                </div>
                <div>
                  <div class="font-semibold text-slate-900 group-hover:text-sky-600 transition-colors">Wuko {d.name}</div>
                  <div class="text-sm text-slate-500">Sprawdź szczegóły →</div>
                </div>
              </div>
              <Icon name="arrow-right" class="w-4 h-4 text-slate-300 group-hover:text-sky-500 group-hover:translate-x-1 transition-all" />
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="mb-12">
      <h3 class="text-xl font-bold text-slate-900 mb-6 text-center">Dojeżdżamy także do innych dzielnic</h3>
      <div class="flex flex-wrap justify-center gap-2">
        {withoutPages.map(d => (
          <span class="px-4 py-2 bg-white text-slate-700 rounded-full border border-slate-200 text-sm">{d}</span>
        ))}
      </div>
    </div>

    <div class="text-center">
      <div class="inline-flex flex-wrap items-center justify-center gap-6 bg-white rounded-full px-6 py-4 shadow-sm">
        <a href={`tel:${siteConfig.phoneTel}`} class="flex items-center gap-2 text-slate-700 hover:text-sky-600 transition-colors">
          <Icon name="phone" class="w-5 h-5 text-sky-500" />
          <span class="font-semibold">Zadzwoń: {siteConfig.phone}</span>
        </a>
      </div>
    </div>
  </div>
</section>
