---
import Icon from './Icon.astro';
import { siteConfig } from '../config/site';
import { districts } from '../data/districts';

const isHomePage = Astro.url.pathname === '/';

const navLinks = [
  { href: '#uslugi', label: 'Usługi' },
  { href: '#dlaczego-my', label: 'Dlaczego my' },
  { href: '#proces', label: 'Proces' },
  { href: '#cennik', label: 'Cennik' },
  { href: '/opinie', label: 'Opinie' },
  { href: '/poradnik/', label: 'Poradnik' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<nav id="navbar" class="navbar" data-solid={isHomePage ? 'false' : 'true'}>
  <div class="nav-inner">
    <div class="nav-row">

      <!-- Logo -->
      <a href="/" class="logo">
        <div class="logo-bg">
          <Icon name="droplets" class="logo-icon" />
        </div>
        <div class="logo-text">
          <span class="logo-name">{siteConfig.shortName}</span>
          <span class="logo-sub">WARSZAWA</span>
        </div>
      </a>

      <!-- Desktop links -->
      <div class="nav-desktop">
        {navLinks.map(link => (
          <a href={link.href} data-nav-link class="nav-link">{link.label}</a>
        ))}

        <!-- Districts dropdown -->
        <div class="dropdown" id="districts-wrap">
          <button id="districts-btn" class="dropdown-btn">
            Dzielnice
            <Icon name="chevron-down" class="chev" />
          </button>
          <div id="districts-menu" class="dropdown-menu u-hidden">
            <div class="dropdown-inner">
              {districts.map(d => (
                <a href={`/${d.slug}`}>Wuko {d.name}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop CTA -->
      <div class="nav-cta">
        <a href={`tel:${siteConfig.phoneTel}`} class="cta-phone">
          <Icon name="phone" class="cta-ico" />
          <span>{siteConfig.phone}</span>
        </a>
      </div>

      <!-- Mobile button -->
      <button id="mobile-btn" class="mobile-btn" aria-label="Menu">
        <Icon name="menu" id="icon-menu" class="burger-ico" />
        <Icon name="x" id="icon-close" class="burger-ico u-hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu u-hidden">
    <div class="mobile-inner">
      {navLinks.map(link => (
        <a href={link.href} data-nav-link class="mobile-link">{link.label}</a>
      ))}
      <div class="mobile-districts">
        <p class="mobile-districts-title">Dzielnice:</p>
        {districts.map(d => (
          <a href={`/${d.slug}`} class="mobile-link">Wuko {d.name}</a>
        ))}
      </div>
      <a href={`tel:${siteConfig.phoneTel}`} class="mobile-cta">
        <Icon name="phone" class="cta-ico" />
        <span>{siteConfig.phone}</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .navbar[data-solid="true"] {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }
  .navbar[data-solid="false"] {
    background: transparent;
  }

  .nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .nav-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .nav-inner { padding: 0 2rem; } }

  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  @media (min-width: 1024px) { .nav-row { height: 5rem; } }

  /* Logo */
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .logo-bg {
    display: flex;
    padding: 0.5rem;
    border-radius: 0.75rem;
    transition: background 0.3s ease;
  }
  .navbar[data-solid="true"] .logo-bg { background: var(--sky); }
  .navbar[data-solid="false"] .logo-bg {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .logo-icon { width: 1.5rem; height: 1.5rem; transition: color 0.3s ease; }
  .navbar[data-solid="true"] .logo-icon { color: #fff; }
  .navbar[data-solid="false"] .logo-icon { color: #7dd3fc; }

  .logo-text { display: flex; flex-direction: column; }
  .logo-name {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
  }
  @media (min-width: 1024px) { .logo-name { font-size: 1.5rem; } }
  .navbar[data-solid="true"] .logo-name { color: #0f172a; }
  .navbar[data-solid="false"] .logo-name { color: #fff; }
  .logo-sub {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }
  .navbar[data-solid="true"] .logo-sub { color: #0284c7; }
  .navbar[data-solid="false"] .logo-sub { color: #bae6fd; }

  /* Desktop links */
  .nav-desktop { display: none; }
  @media (min-width: 1024px) {
    .nav-desktop { display: flex; align-items: center; gap: 1.5rem; }
  }
  .nav-link {
    position: relative;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .navbar[data-solid="true"] .nav-link { color: #334155; }
  .navbar[data-solid="false"] .nav-link { color: rgba(255, 255, 255, 0.9); }
  .nav-link:hover { color: var(--sky); }

  /* Dropdown */
  .dropdown { position: relative; }
  .dropdown-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.3s ease;
  }
  .navbar[data-solid="true"] .dropdown-btn { color: #334155; }
  .navbar[data-solid="false"] .dropdown-btn { color: rgba(255, 255, 255, 0.9); }
  .dropdown-btn:hover { color: var(--sky); }
  .chev { width: 1rem; height: 1rem; }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    right: 0;
    padding-top: 0.5rem;
    width: 14rem;
  }
  .dropdown-inner {
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    border: 1px solid #f1f5f9;
    padding: 0.5rem 0;
  }
  .dropdown-inner a {
    display: block;
    padding: 0.5rem 1rem;
    color: #334155;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .dropdown-inner a:hover { background: var(--bg-sky); color: #0284c7; }

  /* Desktop CTA */
  .nav-cta { display: none; }
  @media (min-width: 1024px) {
    .nav-cta { display: flex; align-items: center; gap: 1rem; }
  }
  .cta-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(90deg, var(--sky), var(--cyan));
    color: #fff;
    padding: 0.625rem 1.25rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .cta-phone:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 24px rgba(14, 165, 233, 0.3);
  }
  .cta-ico { width: 1rem; height: 1rem; }

  /* Mobile button */
  .mobile-btn {
    display: flex;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  @media (min-width: 1024px) { .mobile-btn { display: none; } }
  .navbar[data-solid="true"] .mobile-btn { color: #334155; }
  .navbar[data-solid="false"] .mobile-btn { color: #fff; }
  .burger-ico { width: 1.5rem; height: 1.5rem; }

  /* Mobile menu */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }
  @media (min-width: 1024px) { .mobile-menu { display: none; } }
  .mobile-inner {
    padding: 1.5rem 1rem;
    max-height: 80vh;
    overflow-y: auto;
  }
  .mobile-link {
    display: block;
    padding: 0.5rem 0;
    color: #334155;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .mobile-link:hover { color: var(--sky); }
  .mobile-districts {
    border-top: 1px solid #e2e8f0;
    padding-top: 1rem;
    margin-top: 1rem;
  }
  .mobile-districts-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #64748b;
    margin-bottom: 0.5rem;
  }
  .mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    background: linear-gradient(90deg, var(--sky), var(--cyan));
    color: #fff;
    padding: 0.75rem 1.25rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    margin-top: 1rem;
  }
</style>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement;
  const isHP = navbar?.dataset.solid === 'false';

  // Zmiana stanu navbara przy scrollu (tylko na stronie glownej) — kolory robi CSS
  if (isHP) {
    window.addEventListener(
      'scroll',
      () => navbar?.setAttribute('data-solid', window.scrollY > 20 ? 'true' : 'false'),
      { passive: true }
    );
  }

  // Mobile menu
  const mobileBtn = document.getElementById('mobile-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('u-hidden');
    iconMenu?.classList.toggle('u-hidden');
    iconClose?.classList.toggle('u-hidden');
  });

  document.querySelectorAll('#mobile-menu a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu?.classList.add('u-hidden');
      iconMenu?.classList.remove('u-hidden');
      iconClose?.classList.add('u-hidden');
    });
  });

  // Districts dropdown (hover)
  const wrap = document.getElementById('districts-wrap');
  const menu = document.getElementById('districts-menu');
  wrap?.addEventListener('mouseenter', () => menu?.classList.remove('u-hidden'));
  wrap?.addEventListener('mouseleave', () => menu?.classList.add('u-hidden'));

  // Smooth scroll / redirect dla linkow kotwicowych
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (!href) return;
      if (window.location.pathname === '/') {
        e.preventDefault();
        document.querySelector(href)?.scrollIntoView({ behavior: 'smooth' });
        mobileMenu?.classList.add('u-hidden');
        iconMenu?.classList.remove('u-hidden');
        iconClose?.classList.add('u-hidden');
      } else {
        e.preventDefault();
        window.location.href = '/' + href;
      }
    });
  });
</script>
