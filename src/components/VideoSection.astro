---
import { siteConfig } from '../config/site';

const videoSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Udrażnianie rur Wuko Warszawa – ciśnieniowe przepychanie w praktyce',
  description:
    'Nagranie z realnej interwencji Wuko Warszawa: ciśnieniowe udrażnianie rury kanalizacyjnej krok po kroku.',
  thumbnailUrl: 'https://i.ytimg.com/vi/FP1NWodBZow/hqdefault.jpg',
  uploadDate: '2026-06-20',
  duration: 'PT1M4S',
  contentUrl: 'https://www.youtube.com/shorts/FP1NWodBZow',
  embedUrl: 'https://www.youtube.com/embed/FP1NWodBZow',
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    url: siteConfig.url,
  },
});
---

<script type="application/ld+json" is:inline set:html={videoSchema} />

<section class="video">
  <div class="video-inner">
    <div class="video-head">
      <h2 class="video-title">Zobacz, jak pracujemy</h2>
      <p class="video-sub">
        Krótkie nagranie z realnej interwencji – ciśnieniowe udrażnianie rury w praktyce.
      </p>
    </div>
    <div class="video-wrap">
      <div
        id="yt-lite"
        class="yt-lite"
        role="button"
        tabindex="0"
        aria-label="Odtwórz wideo: ciśnieniowe udrażnianie rury – Wuko Warszawa"
        data-ytid="FP1NWodBZow"
      >
        <img
          src="https://i.ytimg.com/vi/FP1NWodBZow/hqdefault.jpg"
          alt="Ciśnieniowe udrażnianie rury – Wuko Warszawa"
          loading="lazy"
          width="320"
          height="569"
          class="yt-thumb"
        />
        <span class="yt-overlay"></span>
        <span class="yt-play">
          <svg viewBox="0 0 24 24" class="yt-play-ico" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .video { padding: 4rem 0; background: var(--bg-light); }
  @media (min-width: 1024px) { .video { padding: 5rem 0; } }

  .video-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 640px) { .video-inner { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .video-inner { padding: 0 2rem; } }

  .video-head { text-align: center; max-width: 42rem; margin: 0 auto 2.5rem; }
  .video-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }
  @media (min-width: 640px) { .video-title { font-size: 2.25rem; } }
  .video-sub { font-size: 1.125rem; color: #475569; line-height: 1.7; }

  .video-wrap { display: flex; justify-content: center; }
  .yt-lite {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 9 / 16;
    border-radius: 5px;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(15, 23, 42, 0.1);
    cursor: pointer;
    background: #0f172a;
  }
  .yt-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .yt-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.2);
    transition: background 0.2s ease;
  }
  .yt-lite:hover .yt-overlay { background: rgba(15, 23, 42, 0.1); }
  .yt-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
    transition: transform 0.25s ease;
  }
  .yt-lite:hover .yt-play { transform: translate(-50%, -50%) scale(1.1); }
  .yt-play-ico { width: 1.75rem; height: 1.75rem; color: #0284c7; transform: translateX(2px); }
</style>

<script>
  const liteBox = document.getElementById('yt-lite');
  if (liteBox) {
    const playVideo = () => {
      const id = liteBox.dataset.ytid;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = 'Udrażnianie rur – Wuko Warszawa';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0';
      liteBox.innerHTML = '';
      liteBox.appendChild(iframe);
    };
    liteBox.addEventListener('click', playVideo, { once: true });
    liteBox.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        playVideo();
      }
    });
  }
</script>
